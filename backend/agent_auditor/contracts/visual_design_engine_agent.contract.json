{
  "agent_id": "visual_design_engine_agent",
  "name": "Visual Design Engine Agent",
  "version": "0.1.0",
  "purpose": "Visual Design Engine Agent supports the IdeasForgeAI ui and visual generation workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "ui_and_visual_generation",
  "capabilities": [
    "ui_generation",
    "visual_layout_planning"
  ],
  "required_inputs": [
    "brand_context",
    "screen_requirement"
  ],
  "required_outputs": [
    "ui_plan",
    "layout_structure",
    "style_guidance"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "import-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_import_agent.py --agent backend\\agents\\visual_design_engine_agent.py",
      "timeout_seconds": 30
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  }
}