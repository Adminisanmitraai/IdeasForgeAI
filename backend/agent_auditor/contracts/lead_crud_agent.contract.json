{
  "agent_id": "lead_crud_agent",
  "name": "Lead Crud Agent",
  "version": "0.1.0",
  "purpose": "Lead Crud Agent supports the IdeasForgeAI general agent workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "general_agent",
  "capabilities": [
    "structured_output_generation",
    "task_execution"
  ],
  "required_inputs": [
    "task_requirement"
  ],
  "required_outputs": [
    "agent_result",
    "confidence",
    "notes"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\lead_crud_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  }
}