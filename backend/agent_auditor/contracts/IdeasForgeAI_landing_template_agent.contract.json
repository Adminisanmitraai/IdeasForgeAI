{
  "agent_id": "IdeasForgeAI_landing_template_agent",
  "name": "Ideasforgeai Landing Template Agent",
  "version": "0.1.0",
  "purpose": "Ideasforgeai Landing Template Agent supports the IdeasForgeAI ui and visual generation workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "ui_and_visual_generation",
  "capabilities": [
    "page_structure_generation",
    "template_selection"
  ],
  "required_inputs": [
    "page_type",
    "brand_context",
    "layout_requirement"
  ],
  "required_outputs": [
    "selected_template",
    "layout_plan",
    "implementation_notes"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\IdeasForgeAI_landing_template_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  },
  "accuracy_tests": [
    {
      "name": "agent-type-requirement-alignment-benchmark",
      "command": "python backend\\agent_auditor\\accuracy_benchmarks.py --agent backend\\agents\\IdeasForgeAI_landing_template_agent.py --contract backend\\agent_auditor\\contracts\\IdeasForgeAI_landing_template_agent.contract.json --fail-under 70",
      "timeout_seconds": 30
    }
  ],
  "accuracy_benchmark_level": "type_requirement_baseline_v1"
}