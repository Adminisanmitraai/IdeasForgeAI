{
  "agent_id": "pixel_matched_page_converter_agent",
  "name": "Pixel Matched Page Converter Agent",
  "version": "0.1.0",
  "purpose": "Pixel Matched Page Converter Agent supports the IdeasForgeAI ui and visual generation workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "ui_and_visual_generation",
  "capabilities": [
    "layout_mapping",
    "pixel_region_detection",
    "screenshot_analysis"
  ],
  "required_inputs": [
    "screenshot",
    "target_ui_requirement"
  ],
  "required_outputs": [
    "detected_regions",
    "composer_region",
    "card_regions",
    "css_variables",
    "confidence"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\pixel_matched_page_converter_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "accept_failed_visual_regression_without_repair_plan",
      "accept_ui_patch_when_cards_break",
      "accept_ui_patch_when_composer_enters_browser_chrome",
      "accept_ui_patch_when_pixel_score_regresses",
      "accept_ui_patch_without_visual_regression",
      "apply_css_without_human_approval",
      "apply_css_without_safe_css_patch_plan",
      "apply_pixel_patch_without_frontend_file_mapping",
      "apply_ui_patch_without_pixel_debug_report",
      "auto_apply_css_repair_without_approval",
      "blind_css_override_after_pixel_detection",
      "blind_file_patch",
      "ignore_browser_chrome_check",
      "ignore_low_pixel_confidence",
      "ignore_pixel_auto_repair_critical_issue",
      "patch_css_without_dom_mapping",
      "patch_unknown_selector",
      "patch_unmapped_selector",
      "repair_unmapped_selector",
      "stage_unrelated_files",
      "unapproved_live_execution",
      "use_screenshot_as_background"
    ]
  },
  "accuracy_method": "real_pixel_iou_composer_card_detection",
  "minimum_accuracy_score": 80,
  "accuracy_tests": [
    {
      "name": "real-pixel-composer-card-iou-benchmark",
      "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_real_accuracy.py",
      "timeout_seconds": 45
    }
  ],
  "accuracy_benchmark_level": "type_requirement_baseline_v1",
  "debug_outputs": {
    "json_report": "backend/agent_audit_reports/pixel_debug/pixel-debug-report-*.json",
    "visual_overlay": "backend/agent_audit_reports/pixel_debug/pixel-debug-overlay-*.png",
    "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_debug_report.py"
  },
  "pixel_accuracy_wiring": {
    "phase": "PIXEL-AGENT-06",
    "status": "wired_to_real_pixel_benchmark",
    "root_path_rule": "pixel benchmark scripts must resolve ROOT to IdeasForgeAI project root, not backend folder",
    "required_command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_real_accuracy.py"
  },
  "dom_mapping_gate": {
    "phase": "PIXEL-AGENT-08",
    "required_before_css_patch": true,
    "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_dom_mapper.py",
    "minimum_confidence": 60,
    "required_regions": [
      "composer",
      "cards"
    ],
    "output": "backend/agent_audit_reports/pixel_dom_maps/pixel-dom-map-*.json"
  },
  "safe_css_patch_planner": {
    "phase": "PIXEL-AGENT-09",
    "required_before_css_patch": true,
    "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_safe_css_patch_planner.py",
    "approval_required": true,
    "frontend_write_status": "planner_only_no_frontend_write"
  },
  "visual_regression_test": {
    "phase": "PIXEL-AGENT-10",
    "required_after_css_patch": true,
    "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_visual_regression.py --fail-if-regressed",
    "before_after_command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_visual_regression.py --before <before.png> --after <after.png> --fail-if-regressed",
    "output": "backend/agent_audit_reports/pixel_visual_regression/pixel-visual-regression-*.json",
    "required_checks": [
      "after score must not regress",
      "composer must not include browser chrome",
      "cards count must remain valid",
      "composer IoU must not regress",
      "browser region overlap must not regress"
    ]
  },
  "auto_repair_loop": {
    "phase": "PIXEL-AGENT-11",
    "required_when_visual_regression_fails": true,
    "command": "python backend\\agent_auditor\\pixel_benchmarks\\pixel_auto_repair.py",
    "output": "backend/agent_audit_reports/pixel_auto_repairs/pixel-auto-repair-*.json",
    "approval_required": true,
    "frontend_write_status": "suggestion_only_no_frontend_write",
    "repair_types": [
      "composer_position_repair",
      "browser_chrome_overlap_repair",
      "cards_detection_repair",
      "score_regression_repair",
      "screenshot_quality_repair"
    ]
  }
}