{
  "agent_id": "orchestrator_agent",
  "name": "Orchestrator Agent",
  "version": "0.1.0",
  "purpose": "Orchestrator Agent supports the IdeasForgeAI software engineering workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "software_engineering",
  "capabilities": [
    "agent_coordination",
    "workflow_routing"
  ],
  "required_inputs": [
    "user_request",
    "available_agents"
  ],
  "required_outputs": [
    "selected_agent",
    "execution_plan",
    "approval_requirements"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\orchestrator_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  },
  "accuracy_tests": [
    {
      "name": "agent-type-requirement-alignment-benchmark",
      "command": "python backend\\agent_auditor\\accuracy_benchmarks.py --agent backend\\agents\\orchestrator_agent.py --contract backend\\agent_auditor\\contracts\\orchestrator_agent.contract.json --fail-under 70",
      "timeout_seconds": 30
    }
  ],
  "accuracy_benchmark_level": "type_requirement_baseline_v1"
}