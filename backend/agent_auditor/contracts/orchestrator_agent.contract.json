{
  "agent_id": "orchestrator_agent",
  "name": "Orchestrator Agent",
  "version": "0.2.0",
  "purpose": "Route user requests to the correct IdeasForgeAI agent, validate agent health before execution, create a safe execution plan, require approval for risky actions, and return structured status, confidence, fallback, and next-step output.",
  "registry_category": "orchestration",
  "capabilities": [
    "agent_orchestration",
    "agent_routing",
    "registry_awareness",
    "health_score_gate",
    "approval_gate",
    "workflow_planning",
    "fallback_handling",
    "structured_execution_output"
  ],
  "required_inputs": [
    "user_request",
    "available_agents",
    "agent_health_report",
    "project_context"
  ],
  "required_outputs": [
    "selected_agent",
    "routing_reason",
    "execution_plan",
    "approval_required",
    "blocked_agents",
    "fallback_plan",
    "confidence",
    "status"
  ],
  "accuracy_method": "orchestrator_requirement_alignment",
  "minimum_health_score": 75,
  "minimum_accuracy_score": 90,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\orchestrator_agent.py",
      "timeout_seconds": 20
    }
  ],
  "accuracy_tests": [
    {
      "name": "orchestrator-routing-health-approval-benchmark",
      "command": "python backend\\agent_auditor\\accuracy_benchmarks.py --agent backend\\agents\\orchestrator_agent.py --contract backend\\agent_auditor\\contracts\\orchestrator_agent.contract.json --fail-under 90",
      "timeout_seconds": 30
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "read_agent_registry",
      "read_agent_health_report",
      "select_agent",
      "create_execution_plan",
      "return_structured_routing_result"
    ],
    "blocked_actions": [
      "load_blocked_agent",
      "execute_unapproved_risky_action",
      "blind_file_patch",
      "stage_unrelated_files",
      "ignore_agent_health_score"
    ]
  }
}
