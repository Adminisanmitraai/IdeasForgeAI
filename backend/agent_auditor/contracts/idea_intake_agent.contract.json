{
  "agent_id": "idea_intake_agent",
  "name": "Idea Intake Agent",
  "version": "0.1.0",
  "purpose": "Idea Intake Agent supports the IdeasForgeAI requirement intake workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "requirement_intake",
  "capabilities": [
    "structured_output_generation",
    "task_execution"
  ],
  "required_inputs": [
    "raw_user_idea"
  ],
  "required_outputs": [
    "structured_requirement",
    "clarified_scope",
    "agent_routing_plan"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\idea_intake_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  }
}