{
  "agent_id": "frontend_api_connector_agent",
  "name": "Frontend Api Connector Agent",
  "version": "0.1.0",
  "purpose": "Frontend Api Connector Agent supports the IdeasForgeAI deployment and integration workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "deployment_and_integration",
  "capabilities": [
    "structured_output_generation",
    "task_execution"
  ],
  "required_inputs": [
    "task_requirement"
  ],
  "required_outputs": [
    "agent_result",
    "confidence",
    "notes"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "import-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_import_agent.py --agent backend\\agents\\frontend_api_connector_agent.py",
      "timeout_seconds": 30
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  }
}