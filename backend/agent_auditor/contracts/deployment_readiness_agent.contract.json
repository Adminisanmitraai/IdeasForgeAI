{
  "agent_id": "deployment_readiness_agent",
  "name": "Deployment Readiness Agent",
  "version": "0.1.0",
  "purpose": "Deployment Readiness Agent supports the IdeasForgeAI deployment and integration workflow by accepting structured task requirements, performing the agent-specific operation, and returning safe, reviewable, production-oriented output.",
  "registry_category": "deployment_and_integration",
  "capabilities": [
    "deployment_readiness_check",
    "release_validation"
  ],
  "required_inputs": [
    "project_status",
    "deployment_target"
  ],
  "required_outputs": [
    "readiness_report",
    "blocking_issues",
    "release_recommendation"
  ],
  "minimum_health_score": 75,
  "smoke_tests": [
    {
      "name": "static-agent-structure-smoke-test",
      "command": "python backend\\agent_auditor\\smoke_static_agent.py --agent backend\\agents\\deployment_readiness_agent.py",
      "timeout_seconds": 20
    }
  ],
  "safety": {
    "requires_approval": true,
    "allowed_actions": [
      "analyze_input",
      "generate_structured_output",
      "write_agent_report"
    ],
    "blocked_actions": [
      "unapproved_live_execution",
      "blind_file_patch",
      "stage_unrelated_files",
      "use_screenshot_as_background"
    ]
  }
}